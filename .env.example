# Neon Postgres connection string
# Get it from https://neon.tech dashboard > Connection Details
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin token for /admin/waitlist?token=<value>
ADMIN_TOKEN="change-me-to-a-secret-value"

# ---------------------------------------------------------------------------
# Stripe (test keys from https://dashboard.stripe.com/test/apikeys)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — revealed when you register the endpoint in Stripe
# dashboard under Developers > Webhooks > endpoint > Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---------------------------------------------------------------------------
# Click (Uzbekistan payment gateway — sandbox credentials)
# Get from https://merchant.click.uz > Integration > API settings
# ---------------------------------------------------------------------------
CLICK_MERCHANT_ID="your-merchant-id"
CLICK_SERVICE_ID="your-service-id"
CLICK_SECRET_KEY="your-click-secret-key"
# Path Click will POST callbacks to, e.g. /api/payments/click/callback
CLICK_CALLBACK_PATH="/api/payments/click/callback"

# ---------------------------------------------------------------------------
# Telegram bot (created via @BotFather on Telegram)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN="123456789:AABBCCDDEEFFaabbccddeeff-1234567890"
TELEGRAM_BOT_USERNAME="YourBotUsername"
